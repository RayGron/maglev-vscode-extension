{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Extension: Install Dependencies (Linux)",
      "type": "shell",
      "command": "rm -rf node_modules && npm ci",
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Build Debug (Linux)",
      "type": "shell",
      "command": "npm run build:extension:debug",
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Build Release (Linux)",
      "type": "shell",
      "command": "npm run build:extension:release",
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Package Release (Linux)",
      "type": "shell",
      "command": "npm run package:extension:release",
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Check (Linux)",
      "type": "shell",
      "command": "npm run check",
      "group": "test",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Install Dependencies (Windows)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "if (Test-Path node_modules) { Remove-Item node_modules -Recurse -Force }; & npm.cmd ci"
      ],
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Build Debug (Windows)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "npm.cmd run build:extension:debug"
      ],
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Build Release (Windows)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "npm.cmd run build:extension:release"
      ],
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Package Release (Windows)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "npm.cmd run package:extension:release"
      ],
      "group": "build",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Extension: Check (Windows)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/C",
        "npm.cmd run check"
      ],
      "group": "test",
      "problemMatcher": "$tsc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
