{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-cvsc.local/schemas/task-plan.schema.json",
  "title": "TaskPlanResponse",
  "type": "object",
  "required": [
    "summary",
    "steps"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "kind",
          "requiresApproval"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "requiresApproval": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
